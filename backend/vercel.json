{
  "version": 2,
  "buildCommand": "npm install && npx prisma generate",
  "builds": [
    {
      "src": "src/server.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/server.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/overdue-tasks?secret=cron-runtask-2025",
      "schedule": "0 11 * * *"
    }
  ]
}
